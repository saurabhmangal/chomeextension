digraph EcommercePlugin {

  // ── Global layout ───────────────────────────────────────────────────────────
  graph [
    fontname    = "Arial"
    fontsize    = 12
    bgcolor     = "#F8FAFC"
    pad         = 1.2
    splines     = ortho
    rankdir     = TB
    nodesep     = 0.65
    ranksep     = 1.1
    forcelabels = true
  ]
  node [
    fontname = "Arial"
    fontsize = 11
    style    = "filled,rounded"
    shape    = box
    penwidth = 1.5
    margin   = "0.25,0.15"
    width    = 2.6
  ]
  edge [
    fontname  = "Arial"
    fontsize  = 9
    penwidth  = 1.5
    arrowsize = 0.8
    arrowhead = vee
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LEGEND  — pinned to the very bottom
  // ═══════════════════════════════════════════════════════════════════════════
  Legend [
    shape  = none
    margin = "0,0"
    label  = <<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="9"
                     BGCOLOR="#FFFFFF" COLOR="#7F8C8D">
      <TR>
        <TD COLSPAN="5" BGCOLOR="#2C3E50" ALIGN="CENTER">
          <FONT POINT-SIZE="12" COLOR="#FFFFFF"><B>  LEGEND  </B></FONT>
        </TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E8E8E8">
          <FONT POINT-SIZE="9" COLOR="#2C3E50">&#9642;&#160;&#160;Chrome API call</FONT>
        </TD>
        <TD BGCOLOR="#D9EAF5">
          <FONT POINT-SIZE="9" COLOR="#1A5276">&#9642;&#160;&#160;Persistent port<BR/>(streaming progress)</FONT>
        </TD>
        <TD BGCOLOR="#FAD7A0">
          <FONT POINT-SIZE="9" COLOR="#784212"><B>★&#160;&#160;LLM via Tool Router</B><BR/>(goes through invokeTool)</FONT>
        </TD>
        <TD BGCOLOR="#FADBD8">
          <FONT POINT-SIZE="9" COLOR="#7B241C"><B>★&#160;&#160;Direct LLM call</B><BR/>(bypasses Tool Router)</FONT>
        </TD>
        <TD BGCOLOR="#D5F5E3">
          <FONT POINT-SIZE="9" COLOR="#145A32">&#9642;&#160;&#160;No AI involved</FONT>
        </TD>
      </TR>
    </TABLE>>
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 0 — USER
  // ═══════════════════════════════════════════════════════════════════════════
  User [
    label     = "User"
    shape     = circle
    fillcolor = "#2C3E50"
    fontcolor = "#FFFFFF"
    fontsize  = 13
    width     = 1.1
    height    = 1.1
    penwidth  = 0
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 1 — POPUP  (popup.html renders the UI; popup.js drives everything)
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_popup {
    label     = "Popup  (popup.html + popup.js)"
    style     = "filled,rounded"
    fillcolor = "#EBF5FB"
    color     = "#2980B9"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 12
    fontcolor = "#1A5276"

    Popup [
      label     = "Popup UI & Controller\n━━━━━━━━━━━━━━━━━━━━━━\nScan Tabs button\nCompare & CSV button\nSummarize button\nAPI Key settings panel"
      fillcolor = "#2E86C1"
      fontcolor = "#FFFFFF"
      width     = 3.0
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 2 — SCAN APIs  (used directly by Popup — Background not involved)
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_scan {
    label     = "Browser APIs  (Scan flow only)"
    style     = "filled,rounded"
    fillcolor = "#F2F3F4"
    color     = "#7F8C8D"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 11

    ChromeTabs [
      label     = "chrome.tabs\nFind all open tabs"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.2
    ]
    ChromeScripting [
      label     = "chrome.scripting\nInject extractor script\ninto each product tab"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.5
    ]
  }

  WebPages [
    label     = "Product Page DOM\n(Amazon · eBay · any site)\nScript extracts: name, price,\ncategory, URL — returns to Popup"
    shape     = cylinder
    fillcolor = "#FAE5D3"
    fontcolor = "#784212"
    color     = "#CA6F1E"
    penwidth  = 1.5
    style     = filled
    width     = 3.0
  ]

  // Content script lives on the page side too
  ContentJS [
    label     = "content.js\nPassive product detector\nRuns automatically on every\npage load  (no user action)"
    fillcolor = "#1E8449"
    fontcolor = "#FFFFFF"
    width     = 2.8
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 3 — BACKGROUND SERVICE WORKER
  //   Flat layout — no sub-clusters — avoids edge routing across cluster walls
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_background {
    label     = "Background Service Worker  (background.js)"
    style     = "filled,rounded"
    fillcolor = "#F4ECF7"
    color     = "#6C3483"
    penwidth  = 3.0
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#4A235A"

    // ── Entry points (Chrome message channels) ────────────────────────────
    PortListener [
      label     = "Port Listener\n'compareProgress' channel\nReceives the compare request;\nstreams progress events back"
      fillcolor = "#D7BDE2"
      fontcolor = "#4A235A"
      width     = 3.0
    ]

    MsgListener [
      label     = "Message Listener\nHandles: summarizeProducts\nproductDetected\ngetDetectedProducts"
      fillcolor = "#D7BDE2"
      fontcolor = "#4A235A"
      width     = 3.0
    ]

    // ── Tool Router (invokeTool dispatcher) ──────────────────────────────
    Dispatcher [
      label     = "Tool Router\n(invokeTool dispatcher)\nLooks up tool by name\nand calls it"
      shape     = diamond
      fillcolor = "#6C3483"
      fontcolor = "#FFFFFF"
      width     = 3.2
      height    = 1.3
      penwidth  = 2.5
      fontsize  = 11
    ]

    // ── Compare tool chain ────────────────────────────────────────────────
    ToolOrch [
      label     = "Compare Products\n(orchestrator)\nLoops over every tab pair;\ncollects results then exports"
      fillcolor = "#8E44AD"
      fontcolor = "#FFFFFF"
      width     = 3.0
    ]

    ToolPair [
      label     = "Compare Pair\nStep 1 — keyword match  (no LLM)\nStep 2 — LLM if keywords disagree"
      fillcolor = "#8E44AD"
      fontcolor = "#FFFFFF"
      width     = 3.2
    ]

    ToolHeuristic [
      label     = "Category Matcher\nKeyword heuristic  —  no LLM\nFast; runs first for every pair"
      fillcolor = "#D7BDE2"
      fontcolor = "#4A235A"
      style     = "filled,dashed,rounded"
      penwidth  = 1.0
      width     = 2.8
    ]

    // ── Summarize tool chain ──────────────────────────────────────────────
    ToolSummarize [
      label     = "Summarize Products\n(entry point)\nLoops over selected products;\ncollects per-product summaries"
      fillcolor = "#8E44AD"
      fontcolor = "#FFFFFF"
      width     = 3.0
    ]

    SummarizeProduct [
      label     = "Summarize Single Product\n★  DIRECT LLM CALL\nCalls callGemini() directly\n— skips Tool Router entirely"
      fillcolor = "#C0392B"
      fontcolor = "#FFFFFF"
      penwidth  = 3.5
      color     = "#7B241C"
      width     = 3.2
      fontsize  = 10
    ]

    // ── LLM Gateway — both AI paths converge here ─────────────────────────
    ToolGemini [
      label     = "callGemini  —  ★ LLM Gateway\nAll AI requests pass through here\nReads API key from chrome.storage\nCalls Gemini REST API"
      fillcolor = "#E67E22"
      fontcolor = "#FFFFFF"
      penwidth  = 4.0
      color     = "#7D3C00"
      width     = 3.4
      fontsize  = 11
      style     = "filled,rounded"
    ]

    // ── CSV export chain ──────────────────────────────────────────────────
    ToolCsv [
      label     = "Build CSV\nFormats comparison results\ninto a .csv string"
      fillcolor = "#8E44AD"
      fontcolor = "#FFFFFF"
      width     = 2.6
    ]

    ToolDownload [
      label     = "Trigger Download\nCalls chrome.downloads API\nto save the file to disk"
      fillcolor = "#8E44AD"
      fontcolor = "#FFFFFF"
      width     = 2.8
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 4 — EXTERNAL SERVICES  &  OUTPUTS
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_external {
    label     = "External Services"
    style     = "filled,rounded"
    fillcolor = "#FDEDEC"
    color     = "#C0392B"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 12
    fontcolor = "#7B241C"

    GeminiAPI [
      label     = "Google Gemini API\ngemini-2.5-flash\ngenerativelanguage.googleapis.com"
      fillcolor = "#E74C3C"
      fontcolor = "#FFFFFF"
      penwidth  = 2.5
      color     = "#922B21"
      width     = 3.2
    ]
  }

  ChromeDownloads [
    label     = "chrome.downloads\nSaves file to disk"
    fillcolor = "#BDC3C7"
    fontcolor = "#2C3E50"
    width     = 2.6
  ]

  CSVOutput [
    label     = "product_comparison.csv\nsaved to Downloads folder"
    shape     = note
    fillcolor = "#A9DFBF"
    fontcolor = "#145A32"
    color     = "#1E8449"
    penwidth  = 1.5
    style     = filled
    width     = 2.8
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LEGEND ANCHOR  — invisible edges pull Legend to the bottom row
  // (rank constraints on clustered nodes cause Graphviz crashes, so we use
  //  invis edges instead)
  // ═══════════════════════════════════════════════════════════════════════════
  GeminiAPI -> Legend [ style=invis ]
  CSVOutput -> Legend [ style=invis ]

  // ═══════════════════════════════════════════════════════════════════════════
  // EDGES
  // ═══════════════════════════════════════════════════════════════════════════

  // ── A: User opens popup ──────────────────────────────────────────────────
  User -> Popup [
    xlabel    = "opens popup"
    color     = "#566573"
    fontcolor = "#566573"
  ]

  // ── B: Scan flow (Popup calls Chrome APIs directly) ─────────────────────
  //    No back-edge: executeScript injects and also receives the return value
  Popup -> ChromeTabs [
    xlabel    = "1. query open tabs"
    color     = "#7F8C8D"
    fontcolor = "#7F8C8D"
    style     = dashed
  ]
  Popup -> ChromeScripting [
    xlabel    = "2. inject extractor"
    color     = "#7F8C8D"
    fontcolor = "#7F8C8D"
    style     = dashed
  ]
  ChromeScripting -> WebPages [
    xlabel    = "runs script → returns product data"
    color     = "#CA6F1E"
    fontcolor = "#CA6F1E"
    style     = dashed
    dir       = both
    arrowtail = normal
  ]

  // ── C: Content script passive detection ─────────────────────────────────
  ContentJS -> WebPages [
    xlabel    = "reads DOM on load"
    color     = "#1E8449"
    fontcolor = "#1E8449"
    style     = dashed
    dir       = both
    arrowtail = none
  ]
  ContentJS -> MsgListener [
    xlabel    = "sends productDetected"
    color     = "#27AE60"
    fontcolor = "#27AE60"
  ]

  // ── D: Compare flow — persistent port ───────────────────────────────────
  Popup -> PortListener [
    xlabel    = "runtime.connect()  'compareProgress' port"
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
    penwidth  = 2.5
    dir       = both
    arrowtail = vee
  ]
  PortListener -> Dispatcher [
    xlabel    = "routes to compare tool"
    color     = "#5B2C6F"
    fontcolor = "#5B2C6F"
    penwidth  = 2.0
  ]
  Dispatcher -> ToolOrch [
    xlabel    = "compareProductsWithProgress"
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
    penwidth  = 2.0
  ]
  ToolOrch -> ToolPair [
    xlabel    = "for each tab pair"
    color     = "#9B59B6"
    fontcolor = "#9B59B6"
    style     = dashed
  ]
  ToolPair -> ToolHeuristic [
    xlabel    = "step 1: keyword check  (no LLM)"
    color     = "#2E86C1"
    fontcolor = "#2E86C1"
  ]
  // ★ LLM via Tool Router
  ToolPair -> ToolGemini [
    xlabel    = "step 2: ★ LLM fallback  (via Tool Router)"
    color     = "#E67E22"
    fontcolor = "#E67E22"
    penwidth  = 2.8
    style     = dashed
  ]

  // ── E: CSV export after comparison ──────────────────────────────────────
  ToolOrch -> ToolCsv [
    xlabel    = "after all pairs"
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
  ]
  ToolCsv -> ToolDownload [
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
  ]
  ToolDownload -> ChromeDownloads [
    xlabel    = "chrome.downloads.download()"
    color     = "#7F8C8D"
    fontcolor = "#7F8C8D"
    style     = dashed
  ]
  ChromeDownloads -> CSVOutput [
    xlabel    = "file saved"
    color     = "#1E8449"
    fontcolor = "#1E8449"
  ]

  // ── F: Summarize flow — sendMessage ─────────────────────────────────────
  Popup -> MsgListener [
    xlabel    = "sendMessage  summarizeProducts"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.5
    dir       = both
    arrowtail = vee
  ]
  MsgListener -> ToolSummarize [
    xlabel    = "dispatches to tool"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.0
  ]
  ToolSummarize -> SummarizeProduct [
    xlabel    = "once per product"
    color     = "#C0392B"
    fontcolor = "#C0392B"
  ]
  // ★ Direct LLM call — bypasses Tool Router
  SummarizeProduct -> ToolGemini [
    xlabel    = "★ Direct call — bypasses Tool Router"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 3.5
    style     = bold
  ]

  // ── G: LLM Gateway to Gemini API (bidirectional — sends request, gets reply)
  ToolGemini -> GeminiAPI [
    xlabel    = "POST  /v1/models/gemini-2.5-flash:generateContent"
    color     = "#922B21"
    fontcolor = "#922B21"
    penwidth  = 3.0
    style     = bold
    dir       = both
    arrowtail = vee
  ]
}
