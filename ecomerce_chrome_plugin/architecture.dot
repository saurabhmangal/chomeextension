digraph EcommercePlugin {

  // ── Global settings ────────────────────────────────────────────────────────
  graph [
    fontname    = "Arial"
    fontsize    = 13
    bgcolor     = "#F8FAFC"
    pad         = 1.8
    splines     = ortho
    rankdir     = TB
    nodesep     = 2.0
    ranksep     = 2.2
    compound    = true
    forcelabels = true
  ]
  node [
    fontname = "Arial"
    fontsize = 11
    style    = "filled,rounded"
    shape    = box
    penwidth = 1.5
    margin   = "0.35,0.20"
    width    = 2.8
  ]
  edge [
    fontname  = "Arial"
    fontsize  = 10
    penwidth  = 1.6
    arrowsize = 0.85
    arrowhead = vee
  ]

  // ── LEGEND: single HTML table node — no rank pressure ──────────────────────
  Legend [
    shape  = none
    margin = "0,0"
    label  = <<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10"
                     BGCOLOR="#FFFFFF" COLOR="#7F8C8D">
      <TR>
        <TD COLSPAN="5" BGCOLOR="#2C3E50" ALIGN="CENTER">
          <FONT POINT-SIZE="12" COLOR="#FFFFFF"><B>&#160;&#160;LEGEND&#160;&#160;</B></FONT>
        </TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E5E8E8">
          <FONT POINT-SIZE="10" COLOR="#2C3E50">&#9642; Chrome API / message</FONT>
        </TD>
        <TD BGCOLOR="#EAD8F5">
          <FONT POINT-SIZE="10" COLOR="#4A235A">&#9642; Long-lived Port  (bidirectional)</FONT>
        </TD>
        <TD BGCOLOR="#FAD7A0">
          <FONT POINT-SIZE="10" COLOR="#784212"><B>&#9733; LLM via Tool</B>&#160;(invokeTool dispatcher)</FONT>
        </TD>
        <TD BGCOLOR="#FADBD8">
          <FONT POINT-SIZE="10" COLOR="#7B241C"><B>&#9733; Pure LLM Call</B>&#160;(bypasses dispatcher)</FONT>
        </TD>
        <TD BGCOLOR="#D5F5E3">
          <FONT POINT-SIZE="10" COLOR="#145A32">&#9642; Utility&#160;/&#160;No LLM</FONT>
        </TD>
      </TR>
    </TABLE>>
  ]

  // Force Legend to the very top rank, alongside User
  { rank=source; Legend; User }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 0 — USER
  // ═══════════════════════════════════════════════════════════════════════════
  User [
    label     = "User"
    shape     = circle
    fillcolor = "#2C3E50"
    fontcolor = "#FFFFFF"
    fontsize  = 14
    width     = 1.1
    height    = 1.1
    penwidth  = 0
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 1 — POPUP  +  CONTENT SCRIPT
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_popup {
    label     = "Popup Layer"
    style     = "filled,rounded"
    fillcolor = "#EBF5FB"
    color     = "#2980B9"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#1A5276"

    PopupHTML [
      label     = "popup.html\nUI Shell"
      fillcolor = "#AED6F1"
      fontcolor = "#1A5276"
      width     = 2.4
    ]
    PopupJS [
      label     = "popup.js\nUI Controller  &  Orchestrator\nCompare btn   |   Summarize btn   |   API Key panel"
      fillcolor = "#2E86C1"
      fontcolor = "#FFFFFF"
      width     = 4.2
    ]
  }

  subgraph cluster_content {
    label     = "Content Layer"
    style     = "filled,rounded"
    fillcolor = "#E9F7EF"
    color     = "#1E8449"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#145A32"

    ContentJS [
      label     = "content.js\nPassive Product Detector\n(auto-injected on all pages)"
      fillcolor = "#27AE60"
      fontcolor = "#FFFFFF"
      width     = 3.0
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 2 — SCAN APIs  +  WEB PAGES
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_scan {
    label     = "Scan APIs"
    style     = "filled,rounded"
    fillcolor = "#F2F3F4"
    color     = "#7F8C8D"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 12

    ChromeTabs [
      label     = "chrome.tabs\ntabs.query()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.4
    ]
    ChromeScripting [
      label     = "chrome.scripting\nexecuteScript()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.4
    ]
  }

  WebPages [
    label     = "Web Pages  /  DOM\nAmazon  ·  eBay  ·  any product site"
    shape     = cylinder
    fillcolor = "#FAE5D3"
    fontcolor = "#784212"
    penwidth  = 1.5
    color     = "#CA6F1E"
    style     = "filled"
    width     = 3.2
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // BACKGROUND SERVICE WORKER
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_background {
    label     = "Background Service Worker  (background.js)"
    style     = "filled,rounded"
    fillcolor = "#F4ECF7"
    color     = "#6C3483"
    penwidth  = 3.0
    fontname  = "Arial Bold"
    fontsize  = 14
    fontcolor = "#4A235A"

    // ── Runtime Listeners ──────────────────────────────────────────────────
    subgraph cluster_listeners {
      label     = "Chrome Runtime Listeners"
      style     = "filled,rounded"
      fillcolor = "#EAD8F5"
      color     = "#9B59B6"
      penwidth  = 2.0
      fontname  = "Arial Bold"
      fontsize  = 12

      PortListener [
        label     = "onConnect Listener\nPort: 'compareProgress'"
        fillcolor = "#D7BDE2"
        fontcolor = "#4A235A"
        width     = 3.0
      ]
      MsgListener [
        label     = "onMessage Listener\nsummarizeProducts  ·  productDetected  ·  getDetectedProducts"
        fillcolor = "#D7BDE2"
        fontcolor = "#4A235A"
        width     = 4.4
      ]
    }

    // ── invokeTool Dispatcher ──────────────────────────────────────────────
    Dispatcher [
      label     = "invokeTool()\nDispatcher"
      shape     = diamond
      fillcolor = "#6C3483"
      fontcolor = "#FFFFFF"
      width     = 3.2
      height    = 1.3
      penwidth  = 2.5
      fontsize  = 12
    ]

    // ── Tool Registry ──────────────────────────────────────────────────────
    subgraph cluster_tools {
      label     = "Tool Registry"
      style     = "filled,rounded"
      fillcolor = "#EAD8F5"
      color     = "#5B2C6F"
      penwidth  = 2.0
      fontname  = "Arial Bold"
      fontsize  = 12
      fontcolor = "#4A235A"

      // Comparison sub-flow
      subgraph cluster_cmp_tools {
        label     = "Comparison Flow"
        style     = "filled,rounded"
        fillcolor = "#E8DAEF"
        color     = "#8E44AD"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolOrch [
          label     = "compareProductsWithProgress\nOrchestrator Tool"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.4
        ]
        ToolPair [
          label     = "compareProductPair\nHeuristic  +  LLM Fallback"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.2
        ]
        ToolHeuristic [
          label     = "hasSharedProductType()\nKeyword Heuristic  (no LLM)"
          fillcolor = "#D7BDE2"
          fontcolor = "#4A235A"
          style     = "filled,dashed,rounded"
          penwidth  = 1.0
          width     = 3.0
        ]
      }

      // Summarize sub-flow
      subgraph cluster_sum_tools {
        label     = "Summarize Flow"
        style     = "filled,rounded"
        fillcolor = "#FADBD8"
        color     = "#C0392B"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolSummarize [
          label     = "summarizeProducts\nTool wrapper"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.8
        ]
        // ★ PURE LLM PATH — calls callGemini directly
        SummarizeProduct [
          label     = "summarizeProduct()\n★ PURE LLM CALL\nCalls callGemini() directly\n(bypasses invokeTool dispatcher)"
          fillcolor = "#C0392B"
          fontcolor = "#FFFFFF"
          penwidth  = 3.5
          color     = "#7B241C"
          width     = 3.2
          fontsize  = 11
        ]
      }

      // ★ LLM GATEWAY — both paths converge here
      ToolGemini [
        label     = "callGemini\n★ LLM GATEWAY\nAll Gemini calls pass through here"
        fillcolor = "#E67E22"
        fontcolor = "#FFFFFF"
        penwidth  = 4.0
        color     = "#7D3C00"
        width     = 3.4
        fontsize  = 12
        style     = "filled,rounded"
      ]

      // Utility tools
      subgraph cluster_util_tools {
        label     = "Utility Tools  (no LLM)"
        style     = "filled,rounded"
        fillcolor = "#E8DAEF"
        color     = "#8E44AD"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolCsv [
          label     = "generateCsv\nFormatter"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.4
        ]
        ToolDownload [
          label     = "downloadCsv\nChrome Download Trigger"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.8
        ]
        ToolSummary [
          label     = "generateComparisonSummary\nText Formatter"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.2
        ]
      }
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EXTERNAL SERVICES
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_external {
    label     = "External Services"
    style     = "filled,rounded"
    fillcolor = "#FDEDEC"
    color     = "#C0392B"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#7B241C"

    GeminiAPI [
      label     = "Google Gemini API\ngemini-2.5-flash\ngenerativelanguage.googleapis.com"
      fillcolor = "#E74C3C"
      fontcolor = "#FFFFFF"
      penwidth  = 2.5
      color     = "#922B21"
      width     = 3.6
    ]
  }

  // ── Chrome Download API + Output ──────────────────────────────────────────
  subgraph cluster_dl_api {
    label     = "Chrome Download API"
    style     = "filled,rounded"
    fillcolor = "#F2F3F4"
    color     = "#7F8C8D"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 12

    ChromeDownloads [
      label     = "chrome.downloads\ndownload()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.6
    ]
  }

  CSVOutput [
    label     = "product_comparison.csv\nDownloads Folder"
    shape     = note
    fillcolor = "#A9DFBF"
    fontcolor = "#145A32"
    penwidth  = 1.5
    color     = "#1E8449"
    style     = "filled"
    width     = 2.8
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // EDGES
  // ═══════════════════════════════════════════════════════════════════════════

  // ── A: User → Popup ───────────────────────────────────────────────────────
  User      -> PopupHTML [xlabel="opens popup"  color="#566573"  fontcolor="#566573"]
  PopupHTML -> PopupJS   [xlabel="DOM events"   color="#2E86C1"  fontcolor="#2E86C1"]

  // ── B: Scan Tabs ──────────────────────────────────────────────────────────
  PopupJS -> ChromeTabs       [xlabel="tabs.query()"       color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  PopupJS -> ChromeScripting  [xlabel="executeScript()"    color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  ChromeScripting -> WebPages [xlabel="inject extractor"   color="#CA6F1E" fontcolor="#CA6F1E" style=dashed]
  WebPages -> PopupJS         [xlabel="{ name, price, url }"  color="#CA6F1E" fontcolor="#CA6F1E" style=dashed constraint=false]

  // ── C: Content script passive detection ───────────────────────────────────
  ContentJS -> WebPages    [xlabel="reads DOM on load"   color="#27AE60" fontcolor="#27AE60" style=dashed dir=back constraint=false]
  ContentJS -> MsgListener [xlabel="productDetected"     color="#27AE60" fontcolor="#27AE60"]

  // ── D: Compare flow — Port (LLM via Tool path) ────────────────────────────
  PopupJS -> PortListener [
    xlabel    = "runtime.connect()  compareProgress"
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
    penwidth  = 2.8
    dir       = both
    arrowtail = vee
  ]
  PortListener -> Dispatcher [
    xlabel    = "invokeTool -> compareProductsWithProgress"
    color     = "#5B2C6F"
    fontcolor = "#5B2C6F"
    penwidth  = 2.0
  ]

  // ── E: Summarize flow — sendMessage (Pure LLM path) ───────────────────────
  PopupJS -> MsgListener [
    xlabel    = "sendMessage: summarizeProducts"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.8
    dir       = both
    arrowtail = vee
  ]
  MsgListener -> ToolSummarize [
    xlabel    = "tool_summarizeProducts()"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.0
  ]

  // ── F: Dispatcher fans out to tools ───────────────────────────────────────
  Dispatcher -> ToolOrch     [color="#7D3C98" penwidth=2.0]
  Dispatcher -> ToolGemini   [
    xlabel    = "LLM via Tool"
    color     = "#E67E22"
    fontcolor = "#E67E22"
    penwidth  = 2.8
  ]
  Dispatcher -> ToolCsv      [color="#7D3C98"]
  Dispatcher -> ToolDownload [color="#7D3C98"]
  Dispatcher -> ToolSummary  [color="#7D3C98"]

  // ── G: Comparison tool chain ──────────────────────────────────────────────
  ToolOrch -> ToolPair [
    xlabel    = "each pair via invokeTool"
    color     = "#9B59B6"
    fontcolor = "#9B59B6"
    style     = dashed
  ]
  ToolPair -> ToolHeuristic [xlabel="1st: keyword match"  color="#2E86C1" fontcolor="#2E86C1"]

  // ★ LLM via Tool — fallback when heuristic fails
  ToolPair -> ToolGemini [
    xlabel    = "2nd: LLM fallback"
    color     = "#E67E22"
    fontcolor = "#E67E22"
    penwidth  = 2.5
    style     = dashed
  ]

  // ── H: Summarize tool chain ───────────────────────────────────────────────
  ToolSummarize -> SummarizeProduct [
    xlabel    = "per product"
    color     = "#C0392B"
    fontcolor = "#C0392B"
  ]

  // ★ PURE LLM CALL — direct fn, bypasses dispatcher
  SummarizeProduct -> ToolGemini [
    xlabel    = "PURE LLM: tool_callGemini() direct"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 3.5
    style     = bold
  ]

  // ── I: LLM Gateway → Gemini REST API ─────────────────────────────────────
  ToolGemini -> GeminiAPI [
    xlabel    = "POST /v1/models/gemini-2.5-flash:generateContent"
    color     = "#922B21"
    fontcolor = "#922B21"
    penwidth  = 3.5
    style     = bold
    dir       = both
    arrowtail = vee
  ]

  // ── J: CSV download ───────────────────────────────────────────────────────
  ToolDownload -> ChromeDownloads [xlabel="chrome.downloads.download()"  color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  ChromeDownloads -> CSVOutput    [xlabel="saves file"                    color="#1E8449" fontcolor="#1E8449"]
}
