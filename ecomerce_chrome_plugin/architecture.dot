digraph EcommercePlugin {

  // ── Global settings ────────────────────────────────────────────────────────
  graph [
    fontname    = "Arial"
    fontsize    = 13
    bgcolor     = "#F8FAFC"
    pad         = 1.8
    splines     = ortho
    rankdir     = TB
    nodesep     = 2.2
    ranksep     = 2.4
    compound    = true
    forcelabels = true
  ]
  node [
    fontname = "Arial"
    fontsize = 11
    style    = "filled,rounded"
    shape    = box
    penwidth = 1.5
    margin   = "0.35,0.20"
    width    = 2.8
  ]
  edge [
    fontname  = "Arial"
    fontsize  = 10
    penwidth  = 1.6
    arrowsize = 0.85
    arrowhead = vee
  ]

  // ── Legend ─────────────────────────────────────────────────────────────────
  subgraph cluster_legend {
    label     = "Legend"
    style     = "filled,rounded"
    fillcolor = "#FFFFFF"
    color     = "#BDC3C7"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 12

    LA [label="Chrome API / message"                         fillcolor="#E5E8E8" fontcolor="#2C3E50" width=3.4 fontsize=10]
    LB [label="Long-lived Port  (bidirectional)"             fillcolor="#EAD8F5" fontcolor="#4A235A" penwidth=2.5 color="#7D3C98" width=3.4 fontsize=10]
    LC [label="LLM via Tool  (through invokeTool dispatcher)" fillcolor="#FAD7A0" fontcolor="#784212" penwidth=2.5 color="#E67E22" width=3.4 fontsize=10]
    LD [label="Pure LLM Call  (direct fn, bypasses dispatcher)" fillcolor="#FADBD8" fontcolor="#7B241C" penwidth=3.0 color="#C0392B" width=3.4 fontsize=10]
    LE [label="Utility  /  No LLM"                          fillcolor="#D5F5E3" fontcolor="#145A32" penwidth=1.0 color="#1E8449" width=3.4 fontsize=10]
    LA -> LB -> LC -> LD -> LE [style=invis]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 0 — USER
  // ═══════════════════════════════════════════════════════════════════════════
  User [
    label     = "User"
    shape     = circle
    fillcolor = "#2C3E50"
    fontcolor = "#FFFFFF"
    fontsize  = 14
    width     = 1.1
    height    = 1.1
    penwidth  = 0
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 1 — POPUP  +  CONTENT SCRIPT
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_popup {
    label     = "Popup Layer"
    style     = "filled,rounded"
    fillcolor = "#EBF5FB"
    color     = "#2980B9"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#1A5276"

    PopupHTML [
      label     = "popup.html\nUI Shell"
      fillcolor = "#AED6F1"
      fontcolor = "#1A5276"
      width     = 2.4
    ]
    PopupJS [
      label     = "popup.js\nUI Controller  &  Orchestrator\nCompare btn   |   Summarize btn   |   API Key panel"
      fillcolor = "#2E86C1"
      fontcolor = "#FFFFFF"
      width     = 4.0
    ]
  }

  subgraph cluster_content {
    label     = "Content Layer"
    style     = "filled,rounded"
    fillcolor = "#E9F7EF"
    color     = "#1E8449"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#145A32"

    ContentJS [
      label     = "content.js\nPassive Product Detector\n(auto-injected on all pages)"
      fillcolor = "#27AE60"
      fontcolor = "#FFFFFF"
      width     = 3.0
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 2 — SCAN APIs  +  WEB PAGES
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_scan {
    label     = "Scan APIs"
    style     = "filled,rounded"
    fillcolor = "#F2F3F4"
    color     = "#7F8C8D"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 12

    ChromeTabs [
      label     = "chrome.tabs\ntabs.query()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.4
    ]
    ChromeScripting [
      label     = "chrome.scripting\nexecuteScript()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.4
    ]
  }

  WebPages [
    label     = "Web Pages  /  DOM\nAmazon  ·  eBay  ·  any product site"
    shape     = cylinder
    fillcolor = "#FAE5D3"
    fontcolor = "#784212"
    penwidth  = 1.5
    color     = "#CA6F1E"
    style     = "filled"
    width     = 3.2
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // LAYER 3-5 — BACKGROUND SERVICE WORKER
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_background {
    label     = "Background Service Worker  (background.js)"
    style     = "filled,rounded"
    fillcolor = "#F4ECF7"
    color     = "#6C3483"
    penwidth  = 3.0
    fontname  = "Arial Bold"
    fontsize  = 14
    fontcolor = "#4A235A"

    // ── Runtime Listeners ────────────────────────────────────────────────────
    subgraph cluster_listeners {
      label     = "Chrome Runtime Listeners"
      style     = "filled,rounded"
      fillcolor = "#EAD8F5"
      color     = "#9B59B6"
      penwidth  = 2.0
      fontname  = "Arial Bold"
      fontsize  = 12

      PortListener [
        label     = "onConnect Listener\nPort: 'compareProgress'"
        fillcolor = "#D7BDE2"
        fontcolor = "#4A235A"
        width     = 3.0
      ]
      MsgListener [
        label     = "onMessage Listener\nsummarizeProducts  ·  productDetected  ·  getDetectedProducts"
        fillcolor = "#D7BDE2"
        fontcolor = "#4A235A"
        width     = 4.2
      ]
    }

    // ── invokeTool Dispatcher ────────────────────────────────────────────────
    Dispatcher [
      label     = "invokeTool()\nDispatcher"
      shape     = diamond
      fillcolor = "#6C3483"
      fontcolor = "#FFFFFF"
      width     = 3.2
      height    = 1.3
      penwidth  = 2.5
      fontsize  = 12
    ]

    // ── Tool Registry ────────────────────────────────────────────────────────
    subgraph cluster_tools {
      label     = "Tool Registry"
      style     = "filled,rounded"
      fillcolor = "#EAD8F5"
      color     = "#5B2C6F"
      penwidth  = 2.0
      fontname  = "Arial Bold"
      fontsize  = 12
      fontcolor = "#4A235A"

      // Comparison sub-flow
      subgraph cluster_cmp_tools {
        label     = "Comparison Flow"
        style     = "filled,rounded"
        fillcolor = "#E8DAEF"
        color     = "#8E44AD"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolOrch [
          label     = "compareProductsWithProgress\nOrchestrator Tool"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.4
        ]
        ToolPair [
          label     = "compareProductPair\nHeuristic  +  LLM Fallback"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.2
        ]
        ToolHeuristic [
          label     = "hasSharedProductType()\nKeyword Heuristic  (no LLM)"
          fillcolor = "#D7BDE2"
          fontcolor = "#4A235A"
          style     = "filled,dashed,rounded"
          penwidth  = 1.0
          width     = 3.0
        ]
      }

      // Summarize sub-flow
      subgraph cluster_sum_tools {
        label     = "Summarize Flow"
        style     = "filled,rounded"
        fillcolor = "#FADBD8"
        color     = "#C0392B"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolSummarize [
          label     = "summarizeProducts\nTool wrapper"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.8
        ]
        SummarizeProduct [
          label     = "summarizeProduct()\nPure LLM Helper\nBypasses invokeTool dispatcher"
          fillcolor = "#C0392B"
          fontcolor = "#FFFFFF"
          penwidth  = 3.0
          color     = "#7B241C"
          width     = 3.0
        ]
      }

      // Shared LLM gateway
      ToolGemini [
        label     = "callGemini\nLLM Gateway\n\342\230\205 Gemini REST endpoint"
        fillcolor = "#E67E22"
        fontcolor = "#FFFFFF"
        penwidth  = 3.0
        color     = "#A04000"
        width     = 3.0
        fontsize  = 12
      ]

      // Utility tools
      subgraph cluster_util_tools {
        label     = "Utility Tools  (no LLM)"
        style     = "filled,rounded"
        fillcolor = "#E8DAEF"
        color     = "#8E44AD"
        penwidth  = 1.5
        fontname  = "Arial Bold"
        fontsize  = 11

        ToolCsv [
          label     = "generateCsv\nFormatter"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.4
        ]
        ToolDownload [
          label     = "downloadCsv\nChrome Download Trigger"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 2.8
        ]
        ToolSummary [
          label     = "generateComparisonSummary\nText Formatter"
          fillcolor = "#8E44AD"
          fontcolor = "#FFFFFF"
          width     = 3.2
        ]
      }
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // BOTTOM LAYER — EXTERNAL  +  BROWSER DOWNLOAD  +  OUTPUT
  // ═══════════════════════════════════════════════════════════════════════════
  subgraph cluster_external {
    label     = "External Services"
    style     = "filled,rounded"
    fillcolor = "#FDEDEC"
    color     = "#C0392B"
    penwidth  = 2.5
    fontname  = "Arial Bold"
    fontsize  = 13
    fontcolor = "#7B241C"

    GeminiAPI [
      label     = "Google Gemini API\ngemini-2.5-flash\ngenerativelanguage.googleapis.com"
      fillcolor = "#E74C3C"
      fontcolor = "#FFFFFF"
      penwidth  = 2.5
      color     = "#922B21"
      width     = 3.4
    ]
  }

  subgraph cluster_dl_api {
    label     = "Chrome Download API"
    style     = "filled,rounded"
    fillcolor = "#F2F3F4"
    color     = "#7F8C8D"
    penwidth  = 1.5
    fontname  = "Arial Bold"
    fontsize  = 12

    ChromeDownloads [
      label     = "chrome.downloads\ndownload()"
      fillcolor = "#BDC3C7"
      fontcolor = "#2C3E50"
      width     = 2.6
    ]
  }

  CSVOutput [
    label     = "product_comparison.csv\nDownloads Folder"
    shape     = note
    fillcolor = "#A9DFBF"
    fontcolor = "#145A32"
    penwidth  = 1.5
    color     = "#1E8449"
    style     = "filled"
    width     = 2.8
  ]

  // ═══════════════════════════════════════════════════════════════════════════
  // EDGES
  // xlabel is used throughout (required for splines=ortho; forcelabels=true
  // ensures they always render)
  // ═══════════════════════════════════════════════════════════════════════════

  // ── Flow A: User → Popup ──────────────────────────────────────────────────
  User      -> PopupHTML [xlabel="opens popup"  color="#566573" fontcolor="#566573"]
  PopupHTML -> PopupJS   [xlabel="DOM events"   color="#2E86C1" fontcolor="#2E86C1"]

  // ── Flow B: Scan Tabs ─────────────────────────────────────────────────────
  PopupJS -> ChromeTabs       [xlabel="tabs.query()"       color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  PopupJS -> ChromeScripting  [xlabel="executeScript()"    color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  ChromeScripting -> WebPages [xlabel="inject extractor"   color="#CA6F1E" fontcolor="#CA6F1E" style=dashed]
  WebPages -> PopupJS         [xlabel="{ name, price, url }" color="#CA6F1E" fontcolor="#CA6F1E" style=dashed constraint=false]

  // ── Flow C: Content script passive detection ──────────────────────────────
  ContentJS -> WebPages    [xlabel="reads DOM on load" color="#27AE60" fontcolor="#27AE60" style=dashed dir=back constraint=false]
  ContentJS -> MsgListener [xlabel="productDetected"   color="#27AE60" fontcolor="#27AE60"]

  // ── Flow D: Compare (Port, LLM-via-Tool path) ─────────────────────────────
  PopupJS -> PortListener [
    xlabel    = "runtime.connect()   compareProgress"
    color     = "#7D3C98"
    fontcolor = "#7D3C98"
    penwidth  = 2.8
    dir       = both
    arrowtail = vee
  ]
  PortListener -> Dispatcher [
    xlabel    = "invokeTool → compareProductsWithProgress"
    color     = "#5B2C6F"
    fontcolor = "#5B2C6F"
    penwidth  = 2.0
  ]

  // ── Flow E: Summarize (sendMessage, Pure-LLM path) ────────────────────────
  PopupJS -> MsgListener [
    xlabel    = "sendMessage: summarizeProducts"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.8
    dir       = both
    arrowtail = vee
  ]
  MsgListener -> ToolSummarize [
    xlabel    = "tool_summarizeProducts()"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 2.0
  ]

  // ── Flow F: Dispatcher fans out ───────────────────────────────────────────
  Dispatcher -> ToolOrch    [color="#7D3C98" penwidth=2.0]
  Dispatcher -> ToolGemini  [xlabel="LLM via Tool" color="#E67E22" fontcolor="#E67E22" penwidth=2.8]
  Dispatcher -> ToolCsv     [color="#7D3C98"]
  Dispatcher -> ToolDownload [color="#7D3C98"]
  Dispatcher -> ToolSummary  [color="#7D3C98"]

  // ── Flow G: Comparison tool chain ─────────────────────────────────────────
  ToolOrch -> ToolPair [
    xlabel    = "each pair via invokeTool"
    color     = "#9B59B6"
    fontcolor = "#9B59B6"
    style     = dashed
  ]
  ToolPair -> ToolHeuristic [xlabel="1st: keyword match"    color="#2E86C1" fontcolor="#2E86C1"]
  ToolPair -> ToolGemini    [xlabel="2nd: LLM fallback"     color="#E67E22" fontcolor="#E67E22" style=dashed]

  // ── Flow H: Summarize tool chain ──────────────────────────────────────────
  ToolSummarize -> SummarizeProduct [
    xlabel    = "per product"
    color     = "#C0392B"
    fontcolor = "#C0392B"
  ]
  SummarizeProduct -> ToolGemini [
    xlabel    = "PURE LLM: tool_callGemini() direct"
    color     = "#C0392B"
    fontcolor = "#C0392B"
    penwidth  = 3.2
    style     = bold
  ]

  // ── Flow I: Gemini REST call ───────────────────────────────────────────────
  ToolGemini -> GeminiAPI [
    xlabel    = "POST /v1/models/gemini-2.5-flash:generateContent"
    color     = "#A04000"
    fontcolor = "#A04000"
    penwidth  = 3.2
    style     = bold
    dir       = both
    arrowtail = vee
  ]

  // ── Flow J: CSV generation and download ───────────────────────────────────
  ToolDownload -> ChromeDownloads [xlabel="chrome.downloads.download()" color="#7F8C8D" fontcolor="#7F8C8D" style=dashed]
  ChromeDownloads -> CSVOutput    [xlabel="saves file" color="#1E8449" fontcolor="#1E8449"]
}
